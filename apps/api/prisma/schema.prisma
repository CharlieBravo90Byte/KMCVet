// ============================================================
// KMCVet — Prisma Schema
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Tenant (Veterinaria) ─────────────────────────────────────
model Tenant {
  id             String   @id @default(uuid())
  slug           String   @unique
  nombre         String                      // nombre visible / fantasía de la clínica
  nombreEmpresa  String?                     // razón social (puede diferir)
  rutEmpresa     String?                     // RUT tributario ej: 76.123.456-7
  giroClinica    String?                     // giro SII ej: Servicios Veterinarios
  direccionClinica String?
  comunaClinica  String?
  ciudadClinica  String?
  eslogan        String?                     // tagline opcional
  resolucionSII  String?                     // ej: Res. Ex. SII N°XX Año YYYY
  dteTipo        String?  @default("39")     // 39=boleta afecta | 41=boleta exenta
  logoUrl              String?
  plantillaBoletaUrl   String?
  plantillaFacturaUrl  String?
  plantillaNotaCreditoUrl String?
  emailClinica   String?
  telefonos      String?
  colorPrimario  String   @default("#2563EB")
  colorSecundario String  @default("#10B981")
  moneda         String   @default("CLP")
  timezone       String   @default("America/Santiago")
  modulos        String   @default("atencion,inventario")
  activo         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  usuarios    User[]
  propietarios Owner[]
  mascotas    Pet[]
  citas       Appointment[]
  consultas   Consultation[]
  productos   Product[]
  proveedores Supplier[]
  ordenes     PurchaseOrder[]
  tiposAtencion AppointmentType[]
  ventas      Sale[]
  folios      FolioRange[]
  staff       Staff[]
  turnos      Turno[]
  cajaCierres CajaCierre[]
  metas       Meta[]
  hospedajes  Hospedaje[]

  @@map("tenants")
}

// ── Usuario ──────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  tenantId     String
  nombre       String
  email        String
  passwordHash String
  telefono     String?
  rol          UserRole @default(RECEPTIONIST)
  activo       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  citasVeterinario  Appointment[]  @relation("VetAppointments")
  consultas         Consultation[] @relation("VetConsultations")
  movimientosStock  StockMovement[]
  ventas            Sale[]
  cajaCierres       CajaCierre[]

  @@unique([tenantId, email])
  @@map("users")
}

enum UserRole {
  ADMIN
  VET
  RECEPTIONIST
  INVENTORY
}

// ── Propietario ──────────────────────────────────────────────
model Owner {
  id        String   @id @default(uuid())
  tenantId  String
  nombre    String
  documento String
  telefono  String
  email     String?
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mascotas Pet[]
  hospedajes Hospedaje[]

  @@unique([tenantId, documento])
  @@map("owners")
}

// ── Mascota ──────────────────────────────────────────────────
model Pet {
  id                String    @id @default(uuid())
  tenantId          String
  propietarioId     String
  nombre            String
  especie           PetSpecies
  raza              String?
  sexo              PetSex    @default(UNKNOWN)
  fechaNacimiento   DateTime?
  color             String?
  microchip         String?
  fotoUrl           String?
  alergias          String?
  condicionesPrevias String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  propietario Owner        @relation(fields: [propietarioId], references: [id])
  citas      Appointment[]
  consultas  Consultation[]
  pesosHistorico PetWeight[]
  hospedajes Hospedaje[]

  @@map("pets")
}

enum PetSpecies {
  DOG
  CAT
  BIRD
  RABBIT
  REPTILE
  OTHER
}

enum PetSex {
  MALE
  FEMALE
  UNKNOWN
}

// ── Peso histórico de la mascota ─────────────────────────────
model PetWeight {
  id        String   @id @default(uuid())
  petId     String
  pesoKg    Float
  fecha     DateTime @default(now())

  pet Pet @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@map("pet_weights")
}

// ── Cita ─────────────────────────────────────────────────────
model Appointment {
  id            String            @id @default(uuid())
  tenantId      String
  mascotaId     String
  veterinarioId String
  fechaHora     DateTime
  duracionMin   Int               @default(30)
  motivo        String
  estado        AppointmentStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  mascota     Pet           @relation(fields: [mascotaId], references: [id])
  veterinario User          @relation("VetAppointments", fields: [veterinarioId], references: [id])
  consulta    Consultation?

  @@map("appointments")
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// ── Consulta / Atención ──────────────────────────────────────
model Consultation {
  id            String   @id @default(uuid())
  tenantId      String
  citaId        String?  @unique
  veterinarioId String?
  mascotaId     String
  pesoKg        Float?
  temperatura   Float?
  diagnostico   String
  tratamiento   String?
  notas         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  cita        Appointment?     @relation(fields: [citaId], references: [id])
  veterinario User?            @relation("VetConsultations", fields: [veterinarioId], references: [id])
  mascota     Pet              @relation(fields: [mascotaId], references: [id])
  receta      PrescriptionItem[]
  archivos    ConsultationFile[]

  @@map("consultations")
}

// ── Item de receta ───────────────────────────────────────────
model PrescriptionItem {
  id           String @id @default(uuid())
  consultaId   String
  productoId   String
  cantidad     Int
  indicacion   String?

  consulta Consultation @relation(fields: [consultaId], references: [id], onDelete: Cascade)
  producto Product      @relation(fields: [productoId], references: [id])

  @@map("prescription_items")
}

// ── Archivo adjunto ──────────────────────────────────────────
model ConsultationFile {
  id         String   @id @default(uuid())
  consultaId String
  nombre     String
  url        String
  mimetype   String
  createdAt  DateTime @default(now())

  consulta Consultation @relation(fields: [consultaId], references: [id], onDelete: Cascade)

  @@map("consultation_files")
}

// ── Producto (inventario) ─────────────────────────────────────
model Product {
  id               String          @id @default(uuid())
  tenantId         String
  nombre           String
  codigo           String?
  descripcion      String?
  categoria        ProductCategory
  unidad           String          @default("unidad")
  stockActual      Int             @default(0)
  stockMinimo      Int             @default(0)
  stockMaximo      Int?
  precioCosto      Float?
  precioVenta      Float?
  fechaVencimiento DateTime?
  proveedorId      String?
  activo           Boolean         @default(true)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proveedor       Supplier?        @relation(fields: [proveedorId], references: [id])
  movimientos     StockMovement[]
  itemsReceta     PrescriptionItem[]
  itemsOrden      PurchaseOrderItem[]
  itemsVenta      SaleItem[]

  @@unique([tenantId, codigo])
  @@map("products")
}

enum ProductCategory {
  MEDICATION
  FOOD
  SUPPLY
  EQUIPMENT
  OTHER
}

// ── Movimiento de stock ──────────────────────────────────────
model StockMovement {
  id           String            @id @default(uuid())
  productoId   String
  tenantId     String
  usuarioId    String
  tipo         StockMovementType
  cantidad     Int
  referenciaId String?
  notas        String?
  fecha        DateTime          @default(now())

  producto Product @relation(fields: [productoId], references: [id])
  usuario  User    @relation(fields: [usuarioId], references: [id])

  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  ADJUSTMENT
}

// ── Proveedor ─────────────────────────────────────────────────
model Supplier {
  id       String  @id @default(uuid())
  tenantId String
  nombre   String
  contacto String?
  telefono String?
  email    String?
  activo   Boolean @default(true)

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productos Product[]
  ordenes  PurchaseOrder[]

  @@map("suppliers")
}

// ── Tipo de atención (motivo cita) — configurable ─────────────
model AppointmentType {
  id        String   @id @default(uuid())
  tenantId  String
  label     String
  precio    Float?
  activo    Boolean  @default(true)
  orden     Int      @default(0)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("appointment_types")
}

// ── Orden de compra ───────────────────────────────────────────
model PurchaseOrder {
  id            String              @id @default(uuid())
  tenantId      String
  proveedorId   String
  fecha         DateTime            @default(now())
  numeroFactura String?
  estado        PurchaseOrderStatus @default(PENDING)
  notas         String?

  tenant     Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  proveedor  Supplier            @relation(fields: [proveedorId], references: [id])
  items      PurchaseOrderItem[]

  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  RECEIVED
  CANCELLED
}

// ── Item de orden de compra ───────────────────────────────────
model PurchaseOrderItem {
  id             String @id @default(uuid())
  ordenId        String
  productoId     String
  cantidad       Int
  precioUnitario Float

  orden    PurchaseOrder @relation(fields: [ordenId], references: [id], onDelete: Cascade)
  producto Product       @relation(fields: [productoId], references: [id])

  @@map("purchase_order_items")
}
// ── Folio (rango de números de documento tributario) ─────────
model FolioRange {
  id                String    @id @default(uuid())
  tenantId          String
  tipo              String    // boleta | factura | nota_credito
  desde             Int       // primer número del rango
  hasta             Int       // último número del rango
  actual            Int       // próximo número a usar (inicia en `desde`)
  activo            Boolean   @default(true)
  fechaVencimiento  DateTime? // vencimiento gubernamental del rango
  createdAt         DateTime  @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("folio_ranges")
}

// ── Venta ────────────────────────────────────────────────────
model Sale {
  id                String   @id @default(uuid())
  tenantId          String
  usuarioId         String
  fecha             DateTime @default(now())
  total             Float
  notas             String?
  tipoDoc           String   @default("boleta") // boleta | factura | nota_credito
  numeroDocumento   Int?                         // folio asignado
  estado            String   @default("COMPLETADA") // COMPLETADA | PENDIENTE
  rutCliente        String?                      // RUT del cliente (requerido para facturas)
  ventaReferenciaId String?                      // referencia a la venta original (para nota crédito)
  createdAt         DateTime @default(now())

  tenant  Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario User       @relation(fields: [usuarioId], references: [id])
  items   SaleItem[]

  @@map("sales")
}

// ── Item de venta ─────────────────────────────────────────────
model SaleItem {
  id             String  @id @default(uuid())
  saleId         String
  tipo           String  @default("PRODUCTO") // PRODUCTO | SERVICIO
  descripcion    String
  productoId     String?
  cantidad       Int
  precioUnitario Float
  subtotal       Float

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  producto Product? @relation(fields: [productoId], references: [id])

  @@map("sale_items")
}

// ── Personal de la clínica (roster, no requiere login) ───────
model Staff {
  id        String   @id @default(uuid())
  tenantId  String
  nombre    String
  cargo     String   @default("OTRO") // MEDICO_VETERINARIO|ASISTENTE|ENFERMERO|RECEPCIONISTA|TECNICO|OTRO
  email     String?
  telefono  String?
  notas     String?
  activo    Boolean  @default(true)
  color     String   @default("emerald")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  turnos Turno[]

  @@map("staff")
}

// ── Turno de trabajo ─────────────────────────────────────────
model Turno {
  id       String   @id @default(uuid())
  staffId  String
  tenantId String
  fecha    String   // YYYY-MM-DD
  tipo     String   @default("DIA") // MAÑANA|TARDE|NOCHE|DIA|LIBRE
  notas    String?

  staff  Staff  @relation(fields: [staffId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([staffId, fecha])
  @@map("turnos")
}

// ── Cierre de caja diario ────────────────────────────────────
model CajaCierre {
  id                 String   @id @default(uuid())
  tenantId           String
  fechaDia           String   // YYYY-MM-DD (día cuadrado)
  saldoAnterior      Float    @default(0)
  totalEfectivo      Float    @default(0)
  totalTarjeta       Float    @default(0)
  totalTransferencia Float    @default(0)
  totalVentas        Float    @default(0)  // suma ventas del día (desde BD)
  diferencia         Float    @default(0)  // (efectivo+tarjeta+transferencia) - totalVentas
  observaciones      String?
  usuarioId          String
  createdAt          DateTime @default(now())

  tenant  Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  usuario User   @relation(fields: [usuarioId], references: [id])

  @@map("caja_cierres")
}

// ── Metas de ventas ──────────────────────────────────────────
model Meta {
  id        String   @id @default(uuid())
  tenantId  String
  tipo      String   // 'diaria' | 'mensual'
  monto     Float
  activa    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("metas")
}

// ── Hospedaje (Internación) ──────────────────────────────────
model Hospedaje {
  id              String    @id @default(uuid())
  tenantId        String
  petId           String
  propietarioId   String
  fechaEntrada    DateTime
  fechaSalidaEst  DateTime?
  fechaSalidaReal DateTime?
  estado          String    @default("activo")  // 'activo' | 'finalizado' | 'cancelado'
  tipoAlojamiento String?   // 'jaula_pequena' | 'jaula_mediana' | 'jaula_grande' | 'area'
  dieta           String?
  cuidados        String?
  observaciones   String?
  precioPorNoche  Float?
  notas           String?   // notas del personal durante estadía
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pet         Pet    @relation(fields: [petId], references: [id])
  propietario Owner  @relation(fields: [propietarioId], references: [id])

  @@map("hospedajes")
}