{
  "name": "kmcvet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "node scripts/build-all.js",
    "start": "node apps/api/dist/main.js",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "db:generate": "turbo run db:generate",
    "db:migrate": "turbo run db:migrate",
    "db:seed": "turbo run db:seed",
    "db:studio": "pnpm --filter @kmcvet/api db:studio",
    "setup": "pnpm install && pnpm db:generate && pnpm --filter @kmcvet/api db:migrate"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "prettier": "^3.5.3",
    "prisma": "^6.19.3",
    "turbo": "^2.5.0",
    "typescript": "^5.8.2"
  }
}
