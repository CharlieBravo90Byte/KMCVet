# ============================================================
# KMCVet — Variables de entorno
# Copiar este archivo como apps/api/.env y ajustar si es necesario.
# No requiere Docker, PostgreSQL, Redis ni MinIO.
# ============================================================

# ── Base de datos (SQLite embebida, sin servidor externo) ────
# Ruta al archivo .db relativa al directorio de ejecución.
DATABASE_URL="file:./kmcvet.db"

# ── Archivos subidos (carpeta local) ────────────────────────
UPLOADS_DIR=./uploads

# ── Auth ─────────────────────────────────────────────────────
# Genera un valor seguro: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CAMBIA_ESTE_SECRET_POR_UNO_LARGO_Y_ALEATORIO
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CAMBIA_ESTE_REFRESH_SECRET
JWT_REFRESH_EXPIRES_IN=7d

# ── App ──────────────────────────────────────────────────────
NODE_ENV=production
API_PORT=3000
API_PREFIX=api
# En producción ya no hace falta CORS porque la web se sirve desde el mismo proceso
CORS_ORIGINS=http://localhost:3000
